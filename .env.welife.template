# 微信云托管环境变量配置模板
# 使用方法：
# 1. 复制此文件为 .env.welife
# 2. 填写实际的配置信息
# 3. 在微信云托管控制台添加这些环境变量

# ===== 基础配置 =====
FLASK_APP=app.py
FLASK_ENV=production
SECRET_KEY=your-production-secret-key-change-this

# ===== 微信云托管标识 =====
# 设置为true时，应用会使用云端配置
WECHAT_CLOUD=true

# ===== 数据库配置 =====
# 格式: mysql+pymysql://用户名:密码@主机:端口/数据库名
# 示例: mysql+pymysql://lsalumni:password@cdb-example.mysql.tencentcloudapi.com:3306/lsalumni
DATABASE_URL=mysql+pymysql://username:password@host:port/database_name

# 或者使用微信云数据库（如果已开通）
# DATABASE_URL=mysql+pymysql://用户名:密码@内部地址:端口/数据库名

# ===== JWT配置 =====
JWT_SECRET_KEY=your-jwt-secret-key-change-this
# JWT令牌过期时间（秒）
JWT_ACCESS_TOKEN_EXPIRES=86400

# ===== 电子校友卡配置 =====
ELECTRONIC_CARD_SECRET_KEY=your-electronic-card-secret-key

# ===== HMAC动态码密钥配置 =====
HMAC_SECRET_KEY=your-hmac-secret-key-change-this

# ===== Redis缓存配置（可选）=====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_ENABLED=true

# ===== 上传配置 =====
# 上传文件夹路径（微信云托管建议使用/tmp或持久化存储）
UPLOAD_FOLDER=/app/uploads
# 最大上传大小（字节）
MAX_CONTENT_LENGTH=16777216

# ===== 日志配置 =====
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log

# ===== 端口配置 =====
# 微信云托管会自动设置PORT环境变量，无需手动配置
# PORT=8080

# ===== 其他可选配置 =====
# CORS允许的来源（生产环境建议设置具体域名）
# CORS_ORIGINS=https://your-domain.welife.icu

# SSL证书路径（如果使用自定义SSL）
# SSL_CERT_PATH=/app/certificates/cert.pem
# SSL_KEY_PATH=/app/certificates/key.pem

# 邮件配置（如果需要邮件通知功能）
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your-email@example.com
# MAIL_PASSWORD=your-email-password

# 短信配置（如果需要短信通知功能）
# SMS_PROVIDER=tencent
# SMS_API_KEY=your-api-key
# SMS_API_SECRET=your-api-secret
