<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>校友入校登记系统 - 自动化测试</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            margin: 0;
            padding: 20px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            background: white;
            border-radius: 12px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        .header {
            background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
            color: white;
            padding: 30px;
            text-align: center;
        }

        .header h1 {
            margin: 0;
            font-size: 2.5em;
            font-weight: 300;
        }

        .header p {
            margin: 10px 0 0 0;
            opacity: 0.9;
            font-size: 1.1em;
        }

        .content {
            padding: 40px;
        }

        .test-info {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .info-card {
            background: #f8f9fa;
            border-radius: 8px;
            padding: 20px;
            border-left: 4px solid #007bff;
        }

        .info-card h3 {
            margin: 0 0 15px 0;
            color: #007bff;
            font-size: 1.2em;
        }

        .info-card ul {
            margin: 0;
            padding-left: 20px;
        }

        .info-card li {
            margin-bottom: 8px;
            line-height: 1.5;
        }

        .controls {
            text-align: center;
            margin: 40px 0;
        }

        .btn {
            display: inline-block;
            padding: 12px 30px;
            margin: 0 10px;
            border: none;
            border-radius: 25px;
            font-size: 16px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
        }

        .btn-danger {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            color: white;
        }

        .btn-danger:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(245, 87, 108, 0.3);
        }

        .btn-secondary {
            background: #6c757d;
            color: white;
        }

        .btn-secondary:hover {
            background: #5a6268;
            transform: translateY(-2px);
        }

        .console-output {
            background: #1e1e1e;
            color: #f8f8f2;
            border-radius: 8px;
            padding: 20px;
            font-family: 'Courier New', monospace;
            font-size: 14px;
            max-height: 400px;
            overflow-y: auto;
            margin: 20px 0;
        }

        .console-output::-webkit-scrollbar {
            width: 8px;
        }

        .console-output::-webkit-scrollbar-track {
            background: #2d2d2d;
        }

        .console-output::-webkit-scrollbar-thumb {
            background: #555;
            border-radius: 4px;
        }

        .status-indicator {
            display: inline-block;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            margin-right: 8px;
        }

        .status-ready { background: #28a745; }
        .status-running { background: #ffc107; animation: pulse 1s infinite; }
        .status-error { background: #dc3545; }
        .status-success { background: #28a745; }

        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.5; }
            100% { opacity: 1; }
        }

        .requirements {
            background: #fff3cd;
            border: 1px solid #ffeaa7;
            border-radius: 8px;
            padding: 20px;
            margin: 20px 0;
        }

        .requirements h3 {
            margin: 0 0 10px 0;
            color: #856404;
        }

        .requirements ul {
            margin: 0;
            padding-left: 20px;
        }

        .requirements li {
            margin-bottom: 5px;
            color: #856404;
        }

        .footer {
            text-align: center;
            padding: 20px;
            background: #f8f9fa;
            color: #6c757d;
            border-top: 1px solid #dee2e6;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🤖 校友入校登记系统</h1>
            <p>全流程自动化测试平台</p>
        </div>

        <div class="content">
            <div class="requirements">
                <h3>⚠️ 测试环境要求</h3>
                <ul>
                    <li>确保后端服务运行在 http://localhost:5000</li>
                    <li>确保前端服务运行在 http://localhost:8080</li>
                    <li>确保已创建测试账户：教师(teacher001/teacher123)、保安(security001/security123)</li>
                    <li>确保浏览器允许弹窗（用于打开多个窗口）</li>
                    <li>建议使用Chrome或Edge浏览器</li>
                </ul>
            </div>

            <div class="test-info">
                <div class="info-card">
                    <h3>👤 访客端测试</h3>
                    <ul>
                        <li>用户注册（自动生成测试用户）</li>
                        <li>用户登录</li>
                        <li>提交访问申请</li>
                        <li>人脸信息录入</li>
                    </ul>
                </div>

                <div class="info-card">
                    <h3>👨‍🏫 教师端测试</h3>
                    <ul>
                        <li>教师登录</li>
                        <li>查看待审批申请</li>
                        <li>审批访问申请</li>
                        <li>生成访问二维码</li>
                    </ul>
                </div>

                <div class="info-card">
                    <h3>🛡️ 保安端测试</h3>
                    <ul>
                        <li>保安登录</li>
                        <li>二维码验证访客</li>
                        <li>人脸识别验证</li>
                        <li>访客放行操作</li>
                    </ul>
                </div>
            </div>

            <div class="controls">
                <button id="startTest" class="btn btn-primary">
                    🚀 开始自动化测试
                </button>
                <button id="stopTest" class="btn btn-danger">
                    🛑 停止测试
                </button>
                <button id="clearConsole" class="btn btn-secondary">
                    🧹 清空控制台
                </button>
            </div>

            <div style="text-align: center; margin: 20px 0;">
                <span class="status-indicator status-ready" id="statusIndicator"></span>
                <span id="statusText">准备就绪</span>
            </div>

            <div class="console-output" id="console">
                <div style="color: #6c757d;">🤖 自动化测试控制台已初始化...</div>
                <div style="color: #6c757d;">📋 等待开始测试...</div>
            </div>
        </div>

        <div class="footer">
            <p>© 2024 校友入校登记系统 - 自动化测试平台</p>
        </div>
    </div>

    <script src="test_automation.js"></script>
    <script>
        // 控制台输出重定向
        const originalConsole = {
            log: console.log,
            error: console.error,
            warn: console.warn
        };

        const consoleElement = document.getElementById('console');
        const statusIndicator = document.getElementById('statusIndicator');
        const statusText = document.getElementById('statusText');

        function addConsoleMessage(message, type = 'log') {
            const messageDiv = document.createElement('div');
            const timestamp = new Date().toLocaleTimeString();

            let color = '#f8f8f2';
            switch (type) {
                case 'error':
                    color = '#ff6b6b';
                    break;
                case 'warn':
                    color = '#feca57';
                    break;
                case 'success':
                    color = '#48dbfb';
                    break;
            }

            messageDiv.style.color = color;
            messageDiv.textContent = `[${timestamp}] ${message}`;
            consoleElement.appendChild(messageDiv);
            consoleElement.scrollTop = consoleElement.scrollHeight;
        }

        // 重写控制台方法
        console.log = function(...args) {
            originalConsole.log.apply(console, args);
            addConsoleMessage(args.join(' '), 'log');
        };

        console.error = function(...args) {
            originalConsole.error.apply(console, args);
            addConsoleMessage(args.join(' '), 'error');
        };

        console.warn = function(...args) {
            originalConsole.warn.apply(console, args);
            addConsoleMessage(args.join(' '), 'warn');
        };

        // 更新状态
        function updateStatus(status, text) {
            statusIndicator.className = `status-indicator status-${status}`;
            statusText.textContent = text;
        }

        // 绑定按钮事件
        document.getElementById('startTest').addEventListener('click', async () => {
            try {
                updateStatus('running', '测试进行中...');
                console.log('🚀 开始启动自动化测试...');
                console.log('📊 测试流程将按以下步骤执行：');
                console.log('   1. 打开所有系统窗口');
                console.log('   2. 访客注册');
                console.log('   3. 访客登录');
                console.log('   4. 提交访问申请');
                console.log('   5. 录入人脸信息');
                console.log('   6. 教师登录');
                console.log('   7. 教师审批申请');
                console.log('   8. 保安登录');
                console.log('   9. 二维码验证');
                console.log('   10. 人脸验证');
                console.log('   11. 完成测试');
                console.log('');

                await automation.startTest();
                updateStatus('success', '测试完成');

            } catch (error) {
                console.error('❌ 测试执行失败:', error.message);
                updateStatus('error', '测试失败');
            }
        });

        document.getElementById('stopTest').addEventListener('click', () => {
            try {
                automation.stopTest();
                console.log('🛑 测试已停止');
                updateStatus('ready', '测试已停止');
            } catch (error) {
                console.error('❌ 停止测试失败:', error.message);
            }
        });

        document.getElementById('clearConsole').addEventListener('click', () => {
            consoleElement.innerHTML = '<div style="color: #6c757d;">🧹 控制台已清空...</div>';
        });

        // 检查测试环境
        async function checkTestEnvironment() {
            console.log('🔍 检查测试环境...');

            try {
                // 检查后端服务
                const backendResponse = await fetch('http://localhost:5000/api/health');
                if (backendResponse.ok) {
                    console.log('✅ 后端服务正常运行');
                } else {
                    throw new Error('后端服务异常');
                }
            } catch (error) {
                console.warn('⚠️ 无法连接到后端服务，请确保服务运行在 http://localhost:5000');
            }

            try {
                // 检查前端服务
                const frontendResponse = await fetch('http://localhost:8080');
                if (frontendResponse.ok) {
                    console.log('✅ 前端服务正常运行');
                } else {
                    throw new Error('前端服务异常');
                }
            } catch (error) {
                console.warn('⚠️ 无法连接到前端服务，请确保服务运行在 http://localhost:8080');
            }

            console.log('🔍 环境检查完成，可以开始测试');
        }

        // 页面加载完成后检查环境
        window.addEventListener('load', () => {
            setTimeout(checkTestEnvironment, 1000);
        });
    </script>
</body>
</html>